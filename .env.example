# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/

# ── Shortener ─────────────────────────────────────────────────────────────────
SHORTENER_DOMAIN=viralbox.in

# ── Inline Button ─────────────────────────────────────────────────────────────
JOIN_BUTTON_LINK=https://t.me/your_channel

# ── Health Check Port (Koyeb default: 8000) ───────────────────────────────────
PORT=8000
